# MarketBullets Social Automation — Secrets Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Buffer ───────────────────────────────────────────────────────────────────
# Get at: https://buffer.com/developers/api
BUFFER_ACCESS_TOKEN=your_buffer_access_token_here

# Buffer profile IDs — find at:
#   GET https://api.bufferapp.com/1/profiles.json?access_token=YOUR_TOKEN
BUFFER_PROFILE_X=
BUFFER_PROFILE_BLUESKY=
BUFFER_PROFILE_LINKEDIN=
BUFFER_PROFILE_INSTAGRAM=
BUFFER_PROFILE_FACEBOOK=
BUFFER_PROFILE_GOOGLE=

# ── Squarespace ───────────────────────────────────────────────────────────────
# Your Squarespace domain (no trailing slash)
SQUARESPACE_DOMAIN=https://www.marketbulletsllc.com

# RSS feed path — test by visiting this URL in a browser
# Common Squarespace formats:
#   /blog?format=rss   OR   /feed/rss   OR   /commentary?format=rss
SQUARESPACE_RSS_PATH=/blog?format=rss

# Permanent URL for the primary daily chart (WHEAT_SRW_D.png)
# This is the chart embedded in Squarespace — copy the direct image URL
SQUARESPACE_CHART_URL=https://static1.squarespace.com/static/.../WHEAT_SRW_D.png

# ── Behavior ─────────────────────────────────────────────────────────────────
# How often (in minutes) to poll the RSS feed for new commentary
POLL_INTERVAL_MINUTES=15

# Set to "true" to print generated posts without sending to Buffer (testing)
DRY_RUN=false
